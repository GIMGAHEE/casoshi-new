rules_version = '2';

// ============================================================
// CasOshi Firestore Rules
// ============================================================
//
// 현재 모델:
//   - casoshi_livers 컬렉션: 라이버 프로필 + 해시된 비밀번호
//   - 일반 유저는 로그인 없음 (익명) → 읽기는 모두 허용
//   - 운영자/라이버 인증은 프론트 해시 비교로 처리 (초기 단계)
//   - 쓰기는 현재 오픈 상태 유지 (프론트에서만 인증 검증)
//
// ⚠️ 주의: 쓰기가 오픈되어 있어 Firestore 콘솔이나 curl 로 누구나 수정 가능.
//         Phase 3b 에서 Firebase Auth + custom claims 로 전환 예정.
//
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // 라이버 컬렉션
    match /casoshi_livers/{liverId} {
      // 누구나 읽기 가능 (팬이 라이버 목록 보기)
      allow read: if true;

      // 초기 단계: 쓰기도 허용.
      // Phase 3b (Firebase Auth 도입) 이후:
      //   allow write: if request.auth != null &&
      //                (request.auth.token.admin == true ||
      //                 request.auth.uid == liverId);
      allow write: if true;
    }

    // MyOshi (유저 추시 캐릭터) 컬렉션
    //   - 모든 유저의 MyOshi 가 랭킹에 표시되므로 읽기는 공개
    //   - 익명 userId (localStorage) 로 구분되는 단계
    //   - Phase 3b 에서 Firebase Auth uid 로 전환하면
    //     allow write: if request.auth.uid == userId;
    match /casoshi_myoshi/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // 다른 컬렉션은 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
